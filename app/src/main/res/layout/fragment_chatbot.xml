<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header UNET estilo consistente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/unet_blue"
            android:layout_marginBottom="26dp"
            android:elevation="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:background="@color/darkerunet_blue" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="17dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_unet_logo"
                    android:contentDescription="Logo UNET"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ⫹ Asistente ⫺"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:fontFamily="@font/gummy"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tarjeta del chatbot -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/unet_blue_light"
            app:strokeWidth="2dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Título del chatbot -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Asistente UNET"
                    android:textColor="@color/darkerunet_blue"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/gummy"
                    android:gravity="center"
                    android:layout_marginBottom="0dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿En qué puedo ayudarte hoy?"
                    android:textColor="@color/gray"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <!-- Área de mensajes - Altura ajustable -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerChat"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/light_gray"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"

                    android:clipToPadding="false" />

                <!-- Área de entrada de mensajes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:padding="8dp">

                    <!-- Campo de entrada de mensaje -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Escribe tu pregunta..."
                        app:boxCornerRadiusBottomEnd="12dp"

                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="@color/unet_blue"
                        app:startIconDrawable="@drawable/ic_message"
                        app:startIconTint="@color/unet_blue">

                        <AutoCompleteTextView
                            android:id="@+id/inputMensaje"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="50dp"
                            android:minHeight="35dp"
                            android:inputType="text"
                            android:imeOptions="actionSend"
                            android:textSize="16sp"
                            android:padding="8dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón de enviar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnviar"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:icon="@drawable/ic_send"

                        app:iconTint="@color/white"
                        app:backgroundTint="@color/unet_blue"
                        app:cornerRadius="30dp"
                        android:elevation="4dp"
                        style="@style/Widget.MaterialComponents.Button.Icon"
                        />

                </LinearLayout>


            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Información adicional -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬 Asistente virtual de la UNET"
            android:textColor="@color/gray"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="0dp"
            android:padding="8dp" />

        <!-- Espacio reducido para scroll -->
        <View
            android:layout_width="match_parent"
            android:layout_height="10dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>