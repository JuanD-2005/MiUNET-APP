<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔗 Enlaces de Interés"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/purple_700"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_web_unet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌐 Página Oficial UNET" />

        <Button
            android:id="@+id/btn_web_moodle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📘 Moodle UNET"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_web_correo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📧 Correo Institucional"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
