<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:backgroundTint="@color/white"
    android:elevation="8dp"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/unet_blue"
    app:strokeWidth="3dp"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔹 Encabezado con título y botón editar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Título"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/darkerunet_blue"
                android:fontFamily="@font/gummy"
                android:layout_marginEnd="12dp"
                android:paddingStart="4dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 🔹 Botón Editar (solo visible para admin) -->
            <ImageButton
                android:id="@+id/btnEditar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar"
                android:src="@drawable/ic_edit"
                app:tint="@color/unet_blue"
                android:padding="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 🔹 Descripción -->
        <TextView
            android:id="@+id/txtDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción del elemento"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginTop="8dp"
            android:paddingStart="4dp"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- 🔹 Horario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/unet_blue"
                android:layout_marginEnd="8dp"
                android:paddingStart="4dp" />

            <TextView
                android:id="@+id/txtHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Horario"
                android:textSize="14sp"
                android:textColor="@color/unet_blue" />
        </LinearLayout>

        <!-- 🔹 Ubicación -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_location"
                app:tint="@color/unet_blue"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="3dp"
                android:paddingStart="4dp" />

            <TextView
                android:id="@+id/txtUbicacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ubicación"
                android:textSize="14sp"
                android:textColor="@color/unet_blue" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
