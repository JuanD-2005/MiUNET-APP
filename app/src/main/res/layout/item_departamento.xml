<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:backgroundTint="@color/white"
    android:elevation="8dp"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/unet_blue"
    app:strokeWidth="3dp"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔹 Encabezado con nombre del departamento y botón editar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtNombreDepto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Departamento de Ingeniería Electrónica"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/darkerunet_blue"
                android:fontFamily="@font/gummy"
                android:layout_marginEnd="12dp"
                android:paddingStart="15dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 🔹 Botón Editar (solo visible para admin) -->
            <ImageButton
                android:id="@+id/btnEditarDepto"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar departamento"
                android:src="@drawable/ic_edit"
                app:tint="@color/unet_blue"
                android:padding="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 🔹 Horario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/unet_blue"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtHorarioDepto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8:00 a.m. - 4:00 p.m."
                android:textSize="14sp"
                android:textColor="@color/unet_blue" />
        </LinearLayout>

        <!-- 🔹 Ubicación -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_location"
                app:tint="@color/unet_blue"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:id="@+id/txtUbicacionDepto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edificio A, Planta Baja"
                android:textSize="14sp"
                android:textColor="@color/unet_blue"
                />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
