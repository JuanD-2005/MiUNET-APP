<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:backgroundTint="@color/white"
    android:elevation="8dp"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/unet_blue"
    app:strokeWidth="3dp"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔹 Encabezado con título y botón editar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtNombreServicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Servicio de impresión"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/darkerunet_blue"
                android:fontFamily="@font/gummy"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginEnd="16dp"
                android:paddingStart="18dp" />

            <ImageButton
                android:id="@+id/btnEditarServicio"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar servicio"
                android:src="@drawable/ic_edit"
                app:tint="@color/unet_blue"
                android:padding="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 🔹 Descripción -->
        <TextView
            android:id="@+id/txtDescripcionServicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción breve del servicio."
            android:textSize="15sp"
            android:textColor="@color/white"
            android:background="@drawable/background_descripcion"
            android:layout_marginTop="8dp"
            android:padding="12dp" />

        <!-- 🔹 Precio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_money"
                app:tint="@color/unet_blue"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtPrecioServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bs. 5.00 por página"
                android:textSize="14sp"
                android:textColor="@color/unet_blue" />
        </LinearLayout>

        <!-- 🔹 Horario -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/unet_blue"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtHorarioServicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8:00 a.m. - 12:00 p.m."
                android:textSize="14sp"
                android:textColor="@color/unet_blue" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

